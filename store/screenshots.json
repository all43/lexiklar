  "capture": {
    "ios": {
      "open_url": "xcrun simctl openurl booted \"lexiklar://{path}\"",
      "screenshot": "xcrun simctl io booted screenshot \"{output_dir}/{filename}\"",
      "delay_seconds": 2
    },
    "android": {
      "open_url": "adb shell am start -a android.intent.action.VIEW -d \"lexiklar://{path}\" app.lexiklar",
      "screenshot": "adb exec-out screencap -p > \"{output_dir}/{filename}\"",
      "delay_seconds": 2
    }
  },
