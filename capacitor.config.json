{
  "appId": "app.lexiklar",
  "appName": "Lexiklar",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "LiveUpdate": {
      "appId": "app.lexiklar",
      "autoDeleteBundles": true,
      "autoBlockRolledBackBundles": true,
      "enabled": true,
      "readyTimeout": 10000
    },
    "SplashScreen": {
      "launchAutoHide": false
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  }
}
