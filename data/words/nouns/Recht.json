  "senses": [
    {
      "gloss": "staatlich festgelegte und anerkannte Ordnung des menschlichen Zusammenlebens, deren Einhaltung durch staatlich organisierten Zwang garantiert wird",
      "gloss_en": "law",
      "tags": [],
      "example_ids": [
        "5684506541",
        "bdfdcaf805"
      ],
      "synonyms": [],
      "antonyms": [],
      "gloss_en_model": "anthropic/claude-haiku-4-5-20251001",
      "gloss_en_full": "A system of rules and norms established and recognized by the state to govern human coexistence, whose observance is guaranteed through state-organized coercion.",
      "gloss_en_full_model": "anthropic/claude-haiku-4-5-20251001"
    },
    {
      "gloss": "Befugnis einer Person, etwas zu tun, zu unterlassen oder zu verlangen, die sich aus dem Recht im objektiven Sinn ableiten lässt",
      "gloss_en": "right",
      "tags": [],
      "example_ids": [
        "871ccb48de",
        "7e19549d92",
        "9f60e5dfb4"
      ],
      "synonyms": [],
      "antonyms": [],
      "gloss_en_model": "anthropic/claude-haiku-4-5-20251001",
      "gloss_en_full": "The authority or power of a person to do, refrain from doing, or demand something, derived from the law in its objective sense.",
      "gloss_en_full_model": "anthropic/claude-haiku-4-5-20251001"
    },
    {
      "gloss": "Anspruch, der nach dem Rechtsempfinden der Menschen und der Rechtsordnung gerecht und richtig ist",
      "gloss_en": "entitlement",
      "tags": [
