{
  "name": "lexiklar",
  "version": "0.1.0",
  "description": "Offline German dictionary with deep grammar support",
  "type": "module",
  "scripts": {
    "dev": "node scripts/copy-data.js && vite",
    "build": "node scripts/copy-data.js && vite build",
    "preview": "vite preview",
    "copy-data": "node scripts/copy-data.js",
    "download": "node scripts/download.js",
    "transform": "node scripts/transform.js",
    "enrich": "node scripts/enrich-frequency.js",
    "build-index": "node scripts/build-index.js",
    "translate": "node scripts/translate-examples.js",
    "translate-glosses": "node scripts/translate-glosses.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:glosses": "node scripts/test-gloss-translation.js",
    "pipeline": "npm run download && npm run transform && npm run enrich && npm run translate && npm run build-index",
    "pipeline:seed": "npm run download && npm run transform -- --seed && npm run enrich && npm run translate && npm run build-index"
  },
  "dependencies": {
    "@capacitor/core": "^8.1.0",
    "better-sqlite3": "^11.0.0",
    "framework7": "^9.0.3",
    "framework7-icons": "^5.0.5",
    "framework7-vue": "^9.0.3",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
